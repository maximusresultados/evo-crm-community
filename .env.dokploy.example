# =============================================================================
# ChatMax — Dokploy / Docker Compose
# =============================================================================
# Gerado por: ./new-client.sh --client=NOME --backend-domain=DOMINIO --frontend-domain=DOMINIO
# Ou copie este arquivo, preencha as variáveis marcadas com ALTERAR e cole no Dokploy.
# =============================================================================

# -----------------------------------------------------------------------------
# ALTERAR OBRIGATORIAMENTE POR CLIENTE
# -----------------------------------------------------------------------------
BACKEND_URL=https://ALTERAR-api.chatmax.app.br
FRONTEND_URL=https://ALTERAR-app.chatmax.app.br
CORS_ORIGINS=https://ALTERAR-app.chatmax.app.br,https://ALTERAR-api.chatmax.app.br
APP_URL=https://ALTERAR-app.chatmax.app.br
API_URL=https://ALTERAR-api.chatmax.app.br

POSTGRES_DATABASE=evo_ALTERAR

POSTGRES_PASSWORD=ALTERAR
REDIS_PASSWORD=ALTERAR
SECRET_KEY_BASE=ALTERAR
JWT_SECRET_KEY=ALTERAR
DOORKEEPER_JWT_SECRET_KEY=ALTERAR
EVOAI_CRM_API_TOKEN=ALTERAR
ENCRYPTION_KEY=ALTERAR
BOT_RUNTIME_SECRET=ALTERAR

# -----------------------------------------------------------------------------
# FIXO — IGUAL PARA TODOS OS CLIENTES
# -----------------------------------------------------------------------------

# Portas públicas (host)
GATEWAY_PORT=3030
FRONTEND_PORT=5173

# Banco
POSTGRES_USERNAME=postgres

# Ambiente Rails
RAILS_ENV=production
RAILS_MAX_THREADS=5
RAILS_SERVE_STATIC_FILES=true
RAILS_LOG_TO_STDOUT=true

# Auth service
MAILER_SENDER_EMAIL=suporte@chatmax.app.br
DOORKEEPER_JWT_ALGORITHM=hs256
DOORKEEPER_JWT_ISS=evo-auth-service
MFA_ISSUER=chatmax
SIDEKIQ_CONCURRENCY=10
ACTIVE_STORAGE_SERVICE=local

# CRM
DISABLE_TELEMETRY=true
LOG_LEVEL=info
ENABLE_ACCOUNT_SIGNUP=true
ENABLE_PUSH_RELAY_SERVER=true
ENABLE_INBOX_EVENTS=true

# Core
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME=1h
DB_CONN_MAX_IDLE_TIME=30m
JWT_ALGORITHM=HS256
AI_PROCESSOR_VERSION=v1

# Processor
REDIS_DB=0
REDIS_KEY_PREFIX=a2a:
REDIS_TTL=3600
HOST=0.0.0.0
PORT=8000
DEBUG=false
API_TITLE=ChatMax
API_DESCRIPTION=ChatMax Agent Processor
API_VERSION=1.0.0
ORGANIZATION_NAME=Maximus Resultados Comerciais
ORGANIZATION_URL=https://www.chatmax.app.br
TOOLS_CACHE_ENABLED=true
TOOLS_CACHE_TTL=3600

# Bot runtime
LISTEN_ADDR=0.0.0.0:8080
AI_CALL_TIMEOUT_SECONDS=30

# Frontend
VITE_BRAND_LOGO_URL=https://vrwqwnqnqbxppxtpwoae.supabase.co/storage/v1/object/public/CHATMAX%20LOGO/logo-horizontal-dark-2560.png
